# Copy to .env and fill with real values. This file is safe to commit.

# --- Database -----------------------------------------------------------
# Point this at the same MySQL instance the OT server uses (login and
# character data live in the same DB).
DATABASE_URL="mysql://user:password@host:3306/database"

# --- Auth.js ------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Keep this as "true" on Vercel or any reverse-proxy deployment.
AUTH_TRUST_HOST="true"

# --- Public site config -------------------------------------------------
NEXT_PUBLIC_SITE_NAME="OldGlory"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Email (password recovery) ------------------------------------------
# If RESEND_API_KEY is set, reset emails are delivered via Resend
# (https://resend.com). Otherwise the reset link is logged to the server
# console — fine for local dev, not for production.
RESEND_API_KEY=""
MAIL_FROM="no-reply@example.com"

# --- Payments (optional) ------------------------------------------------
# Required to enable the /buypoints gateway. Leave empty to hide it.
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""
